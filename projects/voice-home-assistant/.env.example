# Home Assistant
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here

# DGX Spark - LLM endpoint
# For voice assistant / query tester use Nemotron-Nano (port 8009, fastest)
DGX_URL=http://192.168.1.100:8009
DGX_MODEL=Nemotron-3-Nano-30B-A3B-NVFP4

# STT settings
WHISPER_MODEL=base        # tiny | base | small | medium (larger = more accurate, slower)
WHISPER_DEVICE=cpu        # cpu | cuda (use cuda if running STT on DGX)
SILENCE_THRESHOLD=500     # ms of silence before stopping recording
